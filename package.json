{
  "name": "cchistory-viewer",
  "displayName": "Claude Code History",
  "description": "Browse, group and search Claude Code chat history inside VSCode.",
  "version": "0.1.0",
  "publisher": "diwamoto",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Diwamoto/vscode-cc-history-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/Diwamoto/vscode-cc-history-viewer/issues"
  },
  "homepage": "https://github.com/Diwamoto/vscode-cc-history-viewer#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./out/extension.js",
  "categories": ["Other"],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cchistoryContainer",
          "title": "Claude Code History",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "cchistoryContainer": [
        {
          "id": "cchistory.view",
          "name": "History",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "cchistory.refresh",
        "title": "Claude Code History: Refresh",
        "category": "Claude Code History"
      },
      {
        "command": "cchistory.focus",
        "title": "Claude Code History: Focus View",
        "category": "Claude Code History"
      }
    ],
    "configuration": {
      "title": "Claude Code History",
      "properties": {
        "cchistory.baseDir": {
          "type": "string",
          "default": "",
          "description": "プロジェクトを配置しているディレクトリ。未指定の場合は ~/Projects を読み込む。別ディレクトリ（例: ~/pj）に配置している場合のみ指定する。"
        },
        "cchistory.projectsDir": {
          "type": "string",
          "default": "",
          "description": "Claude Code の会話履歴ディレクトリ。未指定の場合は baseDir の親直下の .claude/projects を自動導出（baseDir が ~/Projects なら ~/.claude/projects）。明示的に上書きしたい場合のみ指定する。"
        },
        "cchistory.refreshDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "description": "ファイル変更検知のdebounce時間 (ms)。"
        }
      }
    }
  },
  "scripts": {
    "build:host": "node esbuild.mjs",
    "build:webview": "vite build",
    "build": "npm run build:host && npm run build:webview",
    "watch:host": "node esbuild.mjs --watch",
    "watch:webview": "vite build --watch",
    "watch": "npm-run-all -p watch:host watch:webview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "p-limit": "^6.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
